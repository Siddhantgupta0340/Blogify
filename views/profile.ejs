<%- include("partials/head") %>
<%- include("partials/nav") %>

<div class="container mt-5">

<h2 class="mb-4">My Blogs</h2>

<div class="row g-4">

<% if(blogs.length === 0){ %>

<p>You have not created any blogs yet.</p>

<% } %>

<% blogs.forEach(blog => { %>

<div class="col-md-4">

<div class="card shadow">

<% if(blog.image){ %>

<img 
src="<%= blog.image %>"
class="card-img-top"
style="height:200px; object-fit:cover;"
>

<% } %>

<div class="card-body">

<h5 class="card-title">

<%= blog.title %>

</h5>

<p class="card-text">

<%= blog.content.substring(0,100) %>...

</p>

<a 
href="/blog/<%= blog._id %>"
class="btn btn-primary"
>

Read Blog

</a>

</div>

</div>

</div>

<% }) %>

</div>

</div>

<%- include("partials/scripts") %>